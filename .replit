run = "python3 run.py"

[nix]
channel = "stable-25_05"
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "gumbo", "harfbuzz", "jbig2dec", "libjpeg_turbo", "libxcrypt", "mupdf", "openjpeg", "pkg-config", "python312Packages.pip", "python312Packages.numpy", "qhull", "swig", "tcl", "tk", "xcbuild"]

[deployment]
build = ["sh", "-c", "python3 -m venv --without-pip --system-site-packages /home/runner/workspace/.venv && curl -sS https://bootstrap.pypa.io/get-pip.py | /home/runner/workspace/.venv/bin/python3 && /home/runner/workspace/.venv/bin/pip install -r requirements.txt"]
run = ["/home/runner/workspace/.venv/bin/python3", "backend/app.py"]
deploymentTarget = "cloudrun"

[env]
REPL_DEPLOYMENT = "true"
PYTHONUNBUFFERED = "1"
SESSION_SECRET = "sensai-feedback-chatbot-session-2026"
PORT = "8080"
